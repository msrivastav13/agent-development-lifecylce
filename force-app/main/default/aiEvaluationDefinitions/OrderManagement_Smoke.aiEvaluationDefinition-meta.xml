<?xml version="1.0" encoding="UTF-8"?>
<AiEvaluationDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Three key scenarios for the OrderManagement agent covering order tracking, cancellation, and guardrail behavior</description>
    <name>OrderManagement Smoke Tests</name>
    <subjectName>OrderManagement</subjectName>
    <subjectType>AGENT</subjectType>
    <subjectVersion>v1</subjectVersion>
    <testCase>
        <expectation>
            <expectedValue>verification</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>Agent asks for the customer&apos;s account number before looking up the order status.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>completeness</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>Where is my order</utterance>
        </inputs>
        <number>1</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>verification</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>Agent asks for the customer&apos;s account number before processing the cancellation request.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>completeness</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>I want to cancel my order 1234</utterance>
        </inputs>
        <number>2</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>verification</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>Agent politely declines and redirects the conversation to order management topics.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>completeness</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>Tell me a joke</utterance>
        </inputs>
        <number>3</number>
    </testCase>
</AiEvaluationDefinition>
